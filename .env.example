# Environment Variables
# Generated from lib/env/server.ts — do not edit manually
# Run: pnpm env:example

# === Database ===
# Neon PostgreSQL connection string (postgresql://...)
DATABASE_URL=

# === Auth ===
# Secret key for better-auth session signing (min 32 chars)
BETTER_AUTH_SECRET=
# Public URL of the app (e.g. http://localhost:3000)
BETTER_AUTH_URL=

# === Stripe ===
# Stripe secret key (starts with sk_)
STRIPE_SECRET_KEY=
# Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=

# === Upstash ===
# Upstash Redis REST URL
UPSTASH_REDIS_REST_URL=
# Upstash Redis REST token
UPSTASH_REDIS_REST_TOKEN=

# === Pinecone ===
# Pinecone API key
PINECONE_API_KEY=

# === Resend ===
# Resend API key for transactional emails
RESEND_API_KEY=

# === PostHog ===
# PostHog project API key (starts with phc_)
NEXT_PUBLIC_POSTHOG_KEY=
# PostHog ingestion host (optional)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# === Sentry ===
# Sentry DSN for error tracking (https://...@sentry.io/...)
NEXT_PUBLIC_SENTRY_DSN=
